{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(cargo build:*)",
      "Bash(cargo init:*)",
      "Bash(cargo test:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(ps:*)",
      "Bash(pstree:*)",
      "Bash(rustc:*)",
      "Bash(rustup update:*)",
      "Bash(rustup show:*)",
      "Bash(tmux capture-pane:*)",
      "Bash(tmux display-message:*)",
      "Bash(tmux list-panes:*)",
      "Bash(tmux list-sessions:*)",
      "Bash(tmux list-windows:*)"
    ]
  }
}
